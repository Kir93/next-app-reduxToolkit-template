{
  "compilerOptions": {
    "esModuleInterop": true,
    "sourceMap": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "alwaysStrict": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "paths": {
      "@api": ["./src/api"],
      "@utils": ["./src/utils"],
      "@config": ["./src/config"],
      "@public": ["./public"],
      "@store": ["./src/store"],
      "@components": ["./src/components"],
      "@provider": ["./src/provider"],
      "@lib": ["./src/lib"],
      "@api/*": ["./src/api/*"],
      "@utils/*": ["./src/utils/*"],
      "@config/*": ["./src/config/*"],
      "@public/*": ["./public/*"],
      "@store/*": ["./src/store/*"],
      "@components/*": ["./src/components/*"],
      "@provider/*": ["./src/provider/*"],
      "@lib/*": ["./src/lib/*"]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
